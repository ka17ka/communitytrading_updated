page {
  background-color: #f8f8f8;
  padding: 0;
  margin: 0;
  width: 100%;
}

.conv-page {
  width: 100%;
  min-height: 100vh;
  padding: 0;
  margin: 0;
  box-sizing: border-box;
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 180rpx;
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
  opacity: 0.6;
}

.empty-text {
  font-size: 28rpx;
  color: #b0b0b0;
}

/* 加载 */
.loading-hint {
  text-align: center;
  padding: 60rpx;
  color: #b0b0b0;
  font-size: 26rpx;
}

/* 会话项 */
.conv-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  background-color: #fff;
  padding: 24rpx 0;
  width: 100%;
  box-sizing: border-box;
}

.conv-item + .conv-item {
  border-top: 1rpx solid #f0f0f0;
}

.conv-item:active {
  background-color: #f5f5f5;
}

/* 头像 */
.conv-avatar-wrap {
  position: relative;
  margin-left: 24rpx;
  margin-right: 18rpx;
  flex-shrink: 0;
}

.conv-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
}

.conv-avatar-default {
  background-color: #e3f0e9;
  display: flex;
  align-items: center;
  justify-content: center;
}

.conv-emoji {
  font-size: 50rpx;
}

/* 未读 */
.conv-dot {
  position: absolute;
  top: 2rpx;
  right: 2rpx;
  width: 18rpx;
  height: 18rpx;
  background-color: #ff5a5f;
  border-radius: 50%;
  border: 2rpx solid #fff;
}

.conv-dot-num {
  position: absolute;
  top: -4rpx;
  right: -6rpx;
  min-width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  text-align: center;
  background-color: #ff5a5f;
  color: #fff;
  font-size: 20rpx;
  border-radius: 16rpx;
  padding: 0 8rpx;
  border: 2rpx solid #fff;
}

/* 信息 */
.conv-info {
  flex: 1;
  overflow: hidden;
  padding-right: 24rpx;
}

.conv-top {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: 6rpx;
}

.conv-name {
  font-size: 30rpx;
  color: #1a1a1a;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 360rpx;
}

.conv-time {
  font-size: 22rpx;
  color: #c0c0c0;
  flex-shrink: 0;
}

.conv-preview {
  font-size: 26rpx;
  color: #999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
