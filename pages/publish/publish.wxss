.container {
  background-color: #f5f5f5;
  min-height: 100vh;
  padding: 8rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

.section {
  background-color: #ffffff;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 8rpx;
  width: 100%;
  box-sizing: border-box;
}

.label {
  font-size: 28rpx;
  color: #333333;
  font-weight: bold;
  display: block;
  margin-bottom: 16rpx;
}

.image-list {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 16rpx;
}

.image-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
}

.preview-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 8rpx;
}

.delete-btn {
  position: absolute;
  top: -16rpx;
  right: -16rpx;
  width: 40rpx;
  height: 40rpx;
  background-color: #ff4444;
  color: #ffffff;
  border-radius: 50%;
  font-size: 28rpx;
  text-align: center;
  line-height: 40rpx;
}

.add-image {
  width: 200rpx;
  height: 200rpx;
  border: 2rpx dashed #cccccc;
  border-radius: 8rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.add-icon {
  font-size: 60rpx;
  color: #cccccc;
  line-height: 60rpx;
}

.add-text {
  font-size: 24rpx;
  color: #cccccc;
  margin-top: 8rpx;
}

.input {
  width: 100%;
  height: 80rpx;
  background-color: #f5f5f5;
  border-radius: 8rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.textarea {
  width: 100%;
  height: 200rpx;
  background-color: #f5f5f5;
  border-radius: 8rpx;
  padding: 16rpx 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.price-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  background-color: #f5f5f5;
  border-radius: 8rpx;
  padding: 0 24rpx;
}

.price-symbol {
  font-size: 32rpx;
  color: #ff4444;
  margin-right: 8rpx;
}

.price-input {
  flex: 1;
  height: 80rpx;
  font-size: 28rpx;
}

.category-list {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 16rpx;
}

.category-item {
  padding: 10rpx 30rpx;
  font-size: 26rpx;
  color: #666666;
  border-radius: 32rpx;
  background-color: #f5f5f5;
}

.category-item.active {
  background-color: #07c160;
  color: #ffffff;
}

.submit-btn {
  width: 100%;
  height: 90rpx;
  background-color: #07c160;
  color: #ffffff;
  font-size: 32rpx;
  border-radius: 12rpx;
  margin-top: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.location-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  background-color: #f5f5f5;
  border-radius: 8rpx;
  padding: 0 24rpx;
  height: 80rpx;
  margin-top: 12rpx;
}

.location-text {
  font-size: 26rpx;
  color: #999999;
  flex: 1;
}

.location-btn {
  font-size: 26rpx;
  color: #07c160;
  flex-shrink: 0;
}