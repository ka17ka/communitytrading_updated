<view class="container">

<view class="group">
  <!-- 用户信息 -->
  <view class="user-section" bindtap="onEditProfile">
    <image wx:if="{{userInfo.avatarUrl && !avatarFailed}}" class="avatar" src="{{userInfo.avatarUrl}}" mode="aspectFill" binderror="onAvatarError"/>
    <view wx:if="{{!userInfo.avatarUrl || avatarFailed}}" class="avatar avatar-default">
      <text class="avatar-emoji">🐻</text>
    </view>
    <view class="user-info">
      <text class="nickname">{{userInfo.nickName || '用户'}}</text>
      <text class="phone">{{userInfo.phone}}</text>
    </view>
    <text class="arrow">›</text>
  </view>

  <!-- 我发布的商品 -->
  <view class="section" bindtap="onMyGoods">
    <text class="label">我发布的商品</text>
    <text class="arrow-dark">›</text>
  </view>

</view>

<!-- 退出登录 -->
<button class="logout-btn" bindtap="onLogout">退出</button>

</view>