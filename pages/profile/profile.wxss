page {
  background-color: #f5f5f5;
}

.group {
  width: 750rpx;
  margin-bottom: 16rpx;
  overflow: visible;
}

.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  padding-top: 0;
}

.user-section {
  display: flex;
  flex-direction: row;
  align-items: center;
  background-color: #07c160;
  padding: 60rpx 32rpx;
  gap: 24rpx;
  width: 750rpx;
  box-sizing: border-box;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background-color: #ffffff;
  flex-shrink: 0;
}

.avatar-default {
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #b6e3f4;
}

.avatar-emoji {
  font-size: 80rpx;
  line-height: 1;
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.nickname {
  font-size: 36rpx;
  color: #ffffff;
  font-weight: bold;
}

.phone {
  font-size: 26rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 8rpx;
}

.arrow {
  font-size: 48rpx;
  color: #ffffff;
  font-weight: bold;
}

.section {
  display: flex;
  flex-direction: row;
  align-items: center;
  background-color: #ffffff;
  padding: 40rpx 32rpx;
  width: 750rpx;
  box-sizing: border-box;
  border-top: 1rpx solid #f5f5f5;
}

.label {
  flex: 1;
  font-size: 30rpx;
  color: #333333;
}

.arrow-dark {
  font-size: 48rpx;
  color: #cccccc;
}

.logout-btn {
  margin-top: 16rpx;
  width: 750rpx;
  height: 90rpx;
  background-color: #ffffff;
  color: #ff4444;
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}