page {
  background-color: #f5f5f5;
  padding: 0;
  margin: 0;
}

.container {
  padding-top: 0;
  padding-bottom: 120rpx;
  box-sizing: border-box;
}

.container-no-bar {
  padding-bottom: 0;
}

.image-swiper {
  width: 100%;
  height: 500rpx;
  display: block;
}

swiper-item {
  width: 100%;
  height: 100%;
}

.goods-image-single {
  width: 100%;
  height: 500rpx;
  display: block;
}

.image-placeholder {
  width: 100%;
  height: 400rpx;
  background-color: #eeeeee;
  display: flex;
  align-items: center;
  justify-content: center;
}

.placeholder-text {
  font-size: 28rpx;
  color: #999999;
}

.goods-image {
  width: 100%;
  height: 100%;
  display: block;
}

.section {
  background-color: #ffffff;
  padding: 24rpx;
  margin-bottom: 12rpx;
  width: 100%;
  box-sizing: border-box;
}

.price-row {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.price {
  font-size: 48rpx;
  color: #ff4444;
  font-weight: bold;
}

.distance {
  font-size: 24rpx;
  color: #999999;
}

.name {
  font-size: 34rpx;
  color: #333333;
  font-weight: bold;
  display: block;
  margin-bottom: 12rpx;
}

.desc {
  font-size: 28rpx;
  color: #666666;
  display: block;
  line-height: 1.6;
}

.seller-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.seller-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  background-color: #eeeeee;
  flex-shrink: 0;
}

.seller-avatar-default {
  background-color: #b6e3f4;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-emoji {
  font-size: 60rpx;
  line-height: 1;
}

.seller-info {
  display: flex;
  flex-direction: column;
}

.seller-name {
  font-size: 30rpx;
  color: #333333;
  font-weight: bold;
}

.seller-desc {
  font-size: 24rpx;
  color: #999999;
  margin-top: 6rpx;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #ffffff;
  padding: 12rpx 24rpx;
  box-shadow: 0 -2rpx 8rpx rgba(0,0,0,0.08);
  box-sizing: border-box;
}

.chat-btn {
  width: 100%;
  height: 90rpx;
  background-color: #07c160;
  color: #ffffff;
  font-size: 32rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.location-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}

.location-info {
  display: flex;
  flex-direction: column;
}

.location-title {
  font-size: 30rpx;
  color: #333333;
  font-weight: bold;
}

.location-text {
  font-size: 24rpx;
  color: #999999;
  margin-top: 6rpx;
}

.location-arrow {
  font-size: 48rpx;
  color: #cccccc;
}