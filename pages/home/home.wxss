.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f5f5f5;
  box-sizing: border-box;
  padding-bottom: 0rpx;
  padding-top: 0rpx;
}

.fixed-top {
  flex-shrink: 0;
  background-color: #ffffff;
  padding-top: 0;
}

.top-bar {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 12rpx 20rpx;
  gap: 12rpx;
}

.msg-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background-color: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.msg-icon {
  font-size: 32rpx;
}

.search-bar {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 8rpx 16rpx;
  gap: 12rpx;
}

.search-input {
  flex: 1;
  height: 64rpx;
  background-color: #f5f5f5;
  border-radius: 32rpx;
  padding: 0 24rpx;
  font-size: 26rpx;
  box-sizing: border-box;
}

.search-btn {
  font-size: 28rpx;
  color: #07c160;
  flex-shrink: 0;
  width: 80rpx;
  text-align: center;
}

.category-list {
  display: flex;
  flex-direction: row;
  white-space: nowrap;
  padding: 12rpx 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.category-item {
  display: inline-block;
  padding: 8rpx 24rpx;
  font-size: 26rpx;
  color: #666666;
  border-radius: 32rpx;
  margin-right: 12rpx;
  background-color: #f5f5f5;
}

.category-item.active {
  background-color: #07c160;
  color: #ffffff;
}

.goods-scroll {
  flex: 1;
  height: 0;
  /* overflow: hidden; */
}

.goods-list {
  padding: 8rpx;
}

.goods-item {
  display: flex;
  flex-direction: row;
  background-color: #ffffff;
  border-radius: 12rpx;
  margin-bottom: 8rpx;
  overflow: hidden;
}

.goods-image {
  width: 200rpx;
  height: 200rpx;
  flex-shrink: 0;
}

.goods-info {
  flex: 1;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.goods-name {
  font-size: 30rpx;
  color: #333333;
  font-weight: bold;
}

.goods-desc {
  font-size: 24rpx;
  color: #999999;
  margin-top: 8rpx;
}

.goods-bottom {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  margin-top: 16rpx;
}

.goods-price {
  font-size: 32rpx;
  color: #ff4444;
  font-weight: bold;
}

.goods-distance {
  font-size: 24rpx;
  color: #999999;
}

