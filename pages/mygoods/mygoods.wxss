page {
  background-color: #f5f5f5;
  min-height: 100vh;
}

.container {
  padding: 0;
  box-sizing: border-box;
}

.empty {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 300rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
}

.goods-item {
  background-color: #ffffff;
  margin-bottom: 2rpx;
  overflow: hidden;
  width: 750rpx;
  box-sizing: border-box;
}

/* 商品主体行（图片+信息） */
.goods-main {
  display: flex;
  flex-direction: row;
}

.goods-image-wrap {
  width: 200rpx;
  height: 200rpx;
  flex-shrink: 0;
  position: relative;
}

.goods-image {
  width: 200rpx;
  height: 200rpx;
}

.goods-image-placeholder {
  width: 200rpx;
  height: 200rpx;
  background-color: #eeeeee;
}

/* 下架遮罩 */
.off-shelf-mask {
  position: absolute;
  top: 0;
  left: 0;
  width: 200rpx;
  height: 200rpx;
  background-color: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
}

.off-shelf-text {
  color: #ffffff;
  font-size: 28rpx;
  font-weight: bold;
  letter-spacing: 4rpx;
}

.goods-info {
  flex: 1;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.goods-name {
  font-size: 30rpx;
  color: #333333;
  font-weight: bold;
}

.goods-desc {
  font-size: 24rpx;
  color: #999999;
  margin-top: 8rpx;
}

.goods-price {
  font-size: 32rpx;
  color: #ff4444;
  font-weight: bold;
  margin-top: 16rpx;
}

/* 操作按钮栏 */
.action-bar {
  display: flex;
  flex-direction: row;
  border-top: 1rpx solid #f0f0f0;
}

.action-btn {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 500;
}

.action-btn + .action-btn {
  border-left: 1rpx solid #f0f0f0;
}

.action-btn-hover {
  background-color: #f5f5f5;
}

.btn-off {
  color: #ff6600;
  font-weight: bold;
}

.btn-on {
  color: #07c160;
}

.btn-edit {
  color: #1890ff;
}

.btn-delete {
  color: #ff4444;
}