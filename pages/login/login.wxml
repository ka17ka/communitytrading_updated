<view class="container">
  <text class="title">小区闲置交易</text>
  <text class="subtitle">欢迎回来</text>

  <view class="form">
    <input
      class="input"
      type="number"
      placeholder="请输入手机号"
      maxlength="11"
      bindinput="onPhoneInput"
    />

    <view class="code-row">
      <input
        class="input code-input"
        type="number"
        placeholder="请输入验证码"
        maxlength="6"
        bindinput="onCodeInput"
      />
      <button class="code-btn" bindtap="sendCode">获取验证码</button>
    </view>

    <button class="login-btn" bindtap="onLogin">登录</button>
  </view>
</view>
