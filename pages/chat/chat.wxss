page {
  height: 100%;
  display: flex;
  flex-direction: column;
  background-color: #f5f5f5;
}

.container {
  display: flex;
  flex-direction: column;
  height: 100%;
  background-color: #f5f5f5;
  overflow: hidden;
  padding: 0rpx;
}

.msg-list {
  flex: 1;
  height: 0;
  padding: 16rpx;
  box-sizing: border-box;
  overflow-y: auto;
}

.msg-item {
  margin-bottom: 24rpx;
}

.msg-row {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
}

.msg-left {
  justify-content: flex-start;
}

.msg-right {
  justify-content: flex-end;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background-color: #eeeeee;
  flex-shrink: 0;
}

.bubble {
  max-width: 520rpx;
  padding: 20rpx 24rpx;
  border-radius: 24rpx;
  font-size: 28rpx;
  line-height: 1.6;
}

.bubble-left {
  background-color: #ffffff;
  margin-left: 16rpx;
}

.bubble-right {
  background-color: #07c160;
  color: #ffffff;
  margin-right: 16rpx;
}

.avatar-default {
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #d9e9dc;
}

.avatar-emoji {
  font-size: 36rpx;
}

.msg-image {
  width: 300rpx;
  border-radius: 8rpx;
}

.input-bar {
  display: flex;
  flex-direction: row;
  align-items: center;
  background-color: #ffffff;
  padding: 16rpx 16rpx 50rpx 16rpx;
  gap: 12rpx;
  border-top: 1rpx solid #eeeeee;
  box-sizing: border-box;
  width: 100%;
}

.msg-input {
  flex: 1;
  height: 72rpx;
  background-color: #f5f5f5;
  border-radius: 36rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.icon-btn {
  width: 72rpx;
  height: 72rpx;
  background-color: #f5f5f5;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.icon-text {
  font-size: 24rpx;
  color: #666666;
}

.send-btn {
  height: 72rpx;
  padding: 0 24rpx;
  background-color: #07c160;
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.send-text {
  font-size: 28rpx;
  color: #ffffff;
}

/* ==========================================
   系统消息（居中）
   ========================================== */
.msg-system {
  display: flex;
  justify-content: center;
  padding: 8rpx 0;
}

.system-text {
  font-size: 24rpx;
  color: #999999;
  background-color: #ededed;
  padding: 8rpx 24rpx;
  border-radius: 8rpx;
  max-width: 80%;
  text-align: center;
  line-height: 1.5;
}

/* ==========================================
   交换联系方式状态栏
   ========================================== */
.swap-bar {
  background-color: #ffffff;
  border-top: 1rpx solid #eeeeee;
  padding: 20rpx 24rpx;
}

.swap-default,
.swap-pending,
.swap-respond,
.swap-done,
.swap-rejected {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.swap-respond {
  flex-wrap: wrap;
  justify-content: center;
}

.swap-hint {
  font-size: 26rpx;
  color: #666666;
}

.swap-btn {
  height: 64rpx;
  padding: 0 32rpx;
  background-color: #07c160;
  color: #ffffff;
  font-size: 26rpx;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.swap-actions {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
  width: 100%;
  justify-content: center;
  margin-top: 12rpx;
}

.swap-agree-btn {
  height: 64rpx;
  padding: 0 40rpx;
  background-color: #07c160;
  color: #ffffff;
  font-size: 26rpx;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.swap-reject-btn {
  height: 64rpx;
  padding: 0 40rpx;
  background-color: #f5f5f5;
  color: #999999;
  font-size: 26rpx;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid #dddddd;
}

.swap-done {
  gap: 8rpx;
}

.swap-phone-label {
  font-size: 26rpx;
  color: #666666;
}

.swap-phone {
  font-size: 28rpx;
  color: #07c160;
  font-weight: bold;
}

.swap-rejected {
  gap: 16rpx;
}

.swap-retry-btn {
  height: 56rpx;
  padding: 0 24rpx;
  background-color: transparent;
  color: #07c160;
  font-size: 24rpx;
  border-radius: 28rpx;
  border: 1rpx solid #07c160;
  display: flex;
  align-items: center;
  justify-content: center;
}
