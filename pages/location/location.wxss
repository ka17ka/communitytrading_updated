/* ==========================================
   位置选择页 — 微信原生列表风格
   全宽行、无圆角、无阴影、层级清晰
   ========================================== */

.page {
  min-height: 100vh;
  background: #F2F2F7;
}

/* ===== 搜索行 ===== */
.search-row {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  background: #FFFFFF;
}
.search-row:active {
  background: #ECECEC;
}
.search-icon {
  font-size: 36rpx;
  margin-right: 24rpx;
}
.search-body {
  flex: 1;
}
.search-title {
  display: block;
  font-size: 30rpx;
  color: #1C1C1E;
  font-weight: 500;
}
.search-sub {
  display: block;
  font-size: 24rpx;
  color: #8E8E93;
  margin-top: 4rpx;
}
.search-chevron {
  font-size: 36rpx;
  color: #C7C7CC;
  margin-left: 16rpx;
}

/* ===== 分隔条 ===== */
.sep {
  height: 12rpx;
  background: #F2F2F7;
}

/* ===== 列表头部 ===== */
.list-head {
  padding: 22rpx 32rpx;
  background: #FFFFFF;
  border-bottom: 1rpx solid #E5E5EA;
}
.list-head-text {
  font-size: 24rpx;
  color: #8E8E93;
}

/* ===== 地址行 ===== */
.addr-row {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  background: #FFFFFF;
  border-bottom: 1rpx solid #F2F2F7;
}
.addr-row:last-child {
  border-bottom: none;
}
.addr-row:active {
  background: #ECECEC;
}
.addr-body {
  flex: 1;
}
.addr-name {
  display: block;
  font-size: 30rpx;
  color: #1C1C1E;
}
.addr-sub {
  display: block;
  font-size: 24rpx;
  color: #8E8E93;
  margin-top: 4rpx;
}
.addr-del {
  font-size: 36rpx;
  color: #C7C7CC;
  padding: 8rpx 16rpx;
}
.addr-del:active {
  color: #FF3B30;
}

/* ===== 空状态 ===== */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 32rpx;
  background: #FFFFFF;
}
.empty-icon {
  font-size: 64rpx;
  margin-bottom: 24rpx;
}
.empty-msg {
  font-size: 28rpx;
  color: #8E8E93;
}
.empty-hint {
  font-size: 24rpx;
  color: #C7C7CC;
  margin-top: 8rpx;
}
