page {
  background-color: #f5f5f5;
  min-height: 100vh;
}

.container {
  padding: 16rpx 0;
  box-sizing: border-box;
}

.section {
  display: flex;
  flex-direction: row;
  align-items: center;
  background-color: #ffffff;
  padding: 32rpx;
  margin-bottom: 2rpx;
  width: 100%;
  box-sizing: border-box;
}

.label {
  font-size: 28rpx;
  color: #333333;
  width: 160rpx;
  flex-shrink: 0;
}

.input {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
}

.phone-text {
  flex: 1;
  font-size: 28rpx;
  color: #999999;
}

.save-btn {
  margin-top: 40rpx;
  width: 100%;
  height: 90rpx;
  background-color: #07c160;
  color: #ffffff;
  font-size: 32rpx;
  border-radius: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}